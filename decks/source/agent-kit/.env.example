# Copy to .env and fill. Used by capture/record-web.mjs for autonomous login + DOM self-correction.
ACTZ_EMAIL=demo@actz.org
ACTZ_PASSWORD=changeme

# Optional target override. Unset = auto-detect: dev server -> local build -> https://actz.org
BASE_URL=

# Login config (pin these to your real app; the recorder falls back to these defaults + DOM self-correction)
ACTZ_LOGIN_URL=/login
ACTZ_EMAIL_SEL=#email
ACTZ_PASSWORD_SEL=#password
ACTZ_SUBMIT_SEL=button[type=submit]

# Stripe MUST be in TEST mode for any checkout/payment capture. Never record real cards.
